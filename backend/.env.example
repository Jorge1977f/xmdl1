# XMDL License API - exemplo de ambiente
# Copie este arquivo para backend/.env e preencha os valores reais.

# URL pública da API de licenças
LICENSE_API_BASE_URL=http://127.0.0.1:8080

# Banco / Supabase
LICENSE_PG_PASSWORD=COLOQUE_SUA_SENHA_SUPABASE_AQUI
LICENSE_SUPABASE_PROJECT_REF=pqwrohnwheesnwueekpv
LICENSE_PG_USER=postgres
LICENSE_PG_HOST=aws-0-sa-east-1.pooler.supabase.com
LICENSE_PG_PORT=6543
LICENSE_PG_DATABASE=postgres

# Segurança
LICENSE_SIGNING_SECRET=TROQUE_ESTE_SEGREDO

# Pix / Mercado Pago
# Use mercadopago para teste real com QR Pix; use simulated para teste visual sem provedor.
LICENSE_PIX_MODE=mercadopago
LICENSE_ALLOW_TEST_PAYMENT=true
LICENSE_PIX_EXPIRATION_MINUTES=60

# Cole aqui o Access Token da área de Test credentials ou Production credentials, conforme o ambiente.
# Não cole usuário/senha da conta de teste aqui.
LICENSE_MP_ACCESS_TOKEN=COLE_AQUI_O_ACCESS_TOKEN

# Opcional: se vazio, o backend monta /api/payments/mercadopago/webhook usando LICENSE_API_BASE_URL
LICENSE_MP_WEBHOOK_URL=

# Opcional: segredo do webhook configurado no painel do Mercado Pago
LICENSE_MP_WEBHOOK_SECRET=
LICENSE_MP_TIMEOUT_SECONDS=30
